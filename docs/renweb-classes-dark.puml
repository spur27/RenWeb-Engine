@startuml RenWeb Architecture

!define INTERFACE_COLOR #1A2332
!define IMPL_COLOR #1F2833
!define MANAGER_COLOR #3D1F4D
!define CORE_COLOR #4A1C1C
!define UTILITY_COLOR #2A2A1A

title RenWeb Engine - Class Architecture (Dark Mode)

skinparam backgroundColor #0D0D0D
skinparam packageStyle rectangle
skinparam shadowing false
skinparam title {
    FontColor #FFFFFF
}
skinparam package {
    BackgroundColor #151515
    BorderColor #333333
    BorderThickness 2
    FontColor #E0E0E0
}
skinparam class {
    BackgroundColor UTILITY_COLOR
    BackgroundColor<<interface>> INTERFACE_COLOR
    BackgroundColor<<implementation>> IMPL_COLOR
    BackgroundColor<<manager>> MANAGER_COLOR
    BackgroundColor<<core>> CORE_COLOR
    BackgroundColor<<utility>> UTILITY_COLOR
    BorderColor #444444
    BorderThickness 1
    ArrowColor #666666
    ArrowFontColor #999999
    FontColor #E0E0E0
    AttributeFontColor #B0B0B0
    StereotypeFontColor #999999
}
skinparam note {
    BackgroundColor #0F0F0F
    BorderColor #333333
    FontColor #B0B0B0
}
skinparam linetype ortho

/' ========== INTERFACES ========== '/

package "Interfaces" #0A0A0A {
    
    interface ILogger <<interface>> {
        +trace(msg: string): void
        +debug(msg: string): void
        +info(msg: string): void
        +warn(msg: string): void
        +error(msg: string): void
        +critical(msg: string): void
        +refresh(fmt: map): void
    }
    
    interface IWebServer <<interface>> {
        +getURL(): string
        +getBasePath(): string
        +getMessages(): const vector<json::value>&
        +start(): void
        +stop(): void
        +isURI(uri: string): bool
        +sendMessage(ip: string, message: json, timeout_s, timeout_ms): void
        +whoAreYou(ip: string, timeout_s, timeout_ms): json::object
    }
    
    interface IWebview <<interface>> {
        +run(): void
        +terminate(): void
        +navigate(url: string): void
        +bind(name: string, fn: function): void
        +unbind(name: string): void
        +dispatch(fn: function): void
        +set_title(title: string): void
        +set_size(width: int, height: int): void
        +set_html(html: string): void
        +eval(js: string): void
        +init(js: string): void
        +window(): optional<void*>
        +widget(): optional<void*>
        +get_controller(): optional<void*>  /' Windows only '/
        +register_navigation_handler(callback): void  /' Windows only '/
    }
    
    interface IProcessManager <<interface>> {
        +dumpProcess(pid: Pid): json::object
        +dumpCurrentProcess(): json::object
        +dumpSystemProcesses(): json::array
        +dumpRenWebProcesses(): json::array
        +dumpChildProcesses(): json::array
        +createSystemProcess(args, detach, share): json::object
        +createRenWebProcess(pages, args, ..): json::object
        +getPid(): Pid
        +kill(pid: Pid, signal: int): void
        +detach(pid: Pid): void
        +send(pid: Pid, message: json): void
        +listen(pid: Pid, lines, tail): vector<string>
        +wait(pid: Pid): void
        +waitAll(): void
        +registerProcess(): void
    }
}

/' ========== TEMPLATE MANAGERS ========== '/

package "Template Managers" #0A0A0A {
    
    class "CallbackManager<Key,RetType,...Params>" as CallbackManager <<manager>> {
        -callbacks: map<Key, function<RetType(Params...)>>
        +add(key: Key, callback: function): CallbackManager*
        +remove(key: Key): CallbackManager*
        +clear(): void
        +run(key: Key, args: Params...): RetType
        +getMap(): const map&
    }
    
    class "InOutManager<Key,OutType,...InTypes>" as InOutManager <<manager>> {
        -inouts: map<Key, pair<function<OutType()>, function<void(InTypes...)>>>
        +add(key: Key, up_down_pair): InOutManager*
        +remove(key: Key): InOutManager*
        +clear(): InOutManager*
        +out(key: Key): OutType
        +in(key: Key, args: InTypes...): void
        +getMap(): const map&
    }
}

/' ========== IMPLEMENTATIONS ========== '/

package "Implementations" #0A0A0A {
    
    class Logger <<implementation>> {
        -{static} max_log_size_bytes: uintmax_t
        -{static} trimmed_log_size_bytes: uintmax_t
        -logger: unique_ptr<spdlog::logger>
        -flags: unique_ptr<LogFlags>
        -file: shared_ptr<File>
        -unable_to_log_msg: bool
        -trimLogFileOnStartup(): void
        +Logger(flags: unique_ptr<LogFlags>)
        +Logger(file: shared_ptr<File>, flags: unique_ptr<LogFlags>)
        +trace/debug/info/warn/error/critical(msg): void
        +refresh(fmt: map<string,string>): void
    }
    
    class FakeLogger <<implementation>> {
        +trace/debug/info/warn/error/critical(msg): void
        +refresh(fmt: map): void
    }
    
    class WebServer <<implementation>> {
        -logger: shared_ptr<ILogger>
        -app: App*
        -base_path: filesystem::path
        -method_callbacks: unique_ptr<CallbackManager>
        -server: unique_ptr<httplib::Server>
        -server_thread: thread
        -port: unsigned short
        -ip: string
        -messages: vector<json::value>
        +{static} generateErrorHTML(code, msg, desc): string
        +WebServer(logger: ILogger, app: App*)
        +getURL(): string
        +getBasePath(): string
        +start(): void
        +stop(): void
        +isURI(uri: string): bool
        +getMessages(): const vector<json::value>&
        +sendMessage/whoAreYou(...): ...
        -setHandles/setMethodCallbacks(): void
        -sendFile/sendStatus/getMimeType(...): ...
    }
    
    class Webview <<implementation>> {
        -webview_impl: unique_ptr<webview::webview>
        +Webview(debug: bool, window: void*, app_id: string, logger: shared_ptr<ILogger>)
        +run/terminate/navigate(...): void
        +bind/unbind/dispatch(...): void
        +eval/init/set_title/set_size/set_html(...): void
        +window/widget(): optional<void*>
        +get_controller(): optional<void*>  /' Windows only '/
        +register_navigation_handler(callback): void  /' Windows only '/
    }
}

/' ========== CORE APPLICATION ========== '/

package "Core" #0A0A0A {
    
    class App <<core>> {
        -logger: shared_ptr<ILogger>
        +orig_args: vector<string>
        +info: unique_ptr<JSON>
        +config: unique_ptr<Config>
        +procm: unique_ptr<IProcessManager>
        +ws: unique_ptr<IWebServer>
        +pm: unique_ptr<PluginManager>
        +w: unique_ptr<IWebview>
        +fns: unique_ptr<WindowFunctions>
        -App(logger: shared_ptr<ILogger>)
        +run(): void
        +{static} showErrorPopup(message: string): void
    }
    
    class AppBuilder <<core>> {
        -opts: map<string, string>
        -argc: int
        -argv: char**
        -logger: shared_ptr<ILogger>
        -info: unique_ptr<JSON>
        -config: unique_ptr<Config>
        -procm: unique_ptr<IProcessManager>
        -w: unique_ptr<IWebview>
        -ws: unique_ptr<IWebServer>
        -fns: unique_ptr<WindowFunctions>
        -pm: unique_ptr<PluginManager>
        +AppBuilder(opts, argc, argv)
        +withLogger/withInfo/withConfig(...): AppBuilder&
        +withProcessManager/withWebview(...): AppBuilder&
        +withWebServer/withWindowFunctions(...): AppBuilder&
        +withPluginManager(...): AppBuilder&
        +build(): unique_ptr<App>
        -validateOpt(opt: string): void
    }
    
    class WindowFunctions <<core>> {
        -logger: shared_ptr<ILogger>
        -app: App*
        -saved_states: map<string, json::value>
        -internal_callbacks: unique_ptr<CM>
        +getsets: unique_ptr<IOM>
        +window_callbacks: unique_ptr<CM>
        +log_callbacks: unique_ptr<CM>
        +filesystem_callbacks: unique_ptr<CM>
        +config_callbacks: unique_ptr<CM>
        +system_callbacks: unique_ptr<CM>
        +process_callbacks: unique_ptr<CM>
        +debug_callbacks: unique_ptr<CM>
        +network_callbacks: unique_ptr<CM>
        +navigate_callbacks: unique_ptr<CM>
        +plugin_callbacks: unique_ptr<CM>
        +WindowFunctions(logger, app)
        +setup/teardown(): WindowFunctions*
        +bindFunction/unbindFunction(...): WindowFunctions*
        +get(property: string): json::value
        +set(property: string, value: json): void
        +getState(): json::object
        +setState(json: json::object): void
        +isFocus(): bool
        -bindDefaults(): WindowFunctions*
        -setGetSets/setWindowCallbacks/..(): WindowFunctions*
    }
    
    class Args <<core>> {
        -desc: options_description
        -argc: int
        -argv: char**
        -opts: map<string, string>
        -arg_callbacks: unique_ptr<CallbackManager>
        -arg_callback_order_vec: vector<string>
        +Args(argc: int, argv: char**)
        +add(names: string, val: value_semantic*, description, callback): Args*
        +run(): void
        -addDefaults(): Args*
    }
}

/' ========== PLUGINS ========== '/

package "Plugin System" #0A0A0A {
    
    class Plugin <<utility>> {
        #name: string
        #internal_name: string
        #version: string
        #description: string
        #repository_url: string
        #logger: shared_ptr<ILogger>
        #functions: map<string, function<json(const json&)>>
        +Plugin(name, internal_name, version, description, repository_url, logger)
        +getName(): string
        +getInternalName(): string
        +getVersion(): string
        +getDescription(): string
        +getRepositoryUrl(): string
        +getFunctions(): const map&
        +getMetadata(): json::object
        #processInput(input): json
        #formatOutput(output): json
    }
    
    class PluginManager <<manager>> {
        -logger: shared_ptr<ILogger>
        -plugins: map<string, shared_ptr<Plugin>>
        +PluginManager(logger)
        +getPlugins(): const map&
        +getPluginList(): json::array
        -loadPlugin(path: filesystem::path): void
        -unloadPlugin(name: string): bool
        -openLibrary(path): LibraryHandle
        -closeLibrary(handle): void
        -resolveSymbol(handle, path, symbol): T
    }
}

/' ========== UTILITIES ========== '/

package "Utilities" #0A0A0A {
    
    class JSON <<utility>> {
        #logger: shared_ptr<ILogger>
        #json_data: json::value
        +file: shared_ptr<File>
        +JSON(logger: shared_ptr<ILogger>, file: shared_ptr<File>)
        +{static} peek(file: File*, key: string): json::value
        +{static} merge(old_data: json::object, new_data: json::object): json::object
        +getJson(): const json::value&
        +getProperty(key: string): json::value
        +setProperty(key: string, value: json::value): void
        +update(new_data: json::object): void
    }
    
    class Config <<utility>> {
        -{static} DEFAULTS_KEY: string
        +{static} ERROR_KEY: string
        +initial_page: string
        +current_page: string
        +Config(logger, current_page: string)
        +Config(logger, current_page: string, file: shared_ptr<File>)
        +getProperty(key: string): json::value
        +setProperty(key: string, value: json::value): void
        +getDefaultProperty(key: string): json::value
        +setDefaultProperty(key: string, value: json::value): void
        +getJson(): const json::value&
        +getDefaultsJson(): const json::value&
        +update(new_data: json::object): void
    }
    
    class File <<utility>> {
        -file_path: filesystem::path
        +File()
        +File(file_path: filesystem::path)
        +exists(): bool
        +read(): shared_ptr<string>
        +write(data: string): void
        +clear(): void
        +getPath(): const path&
        +getName(): path
        +getDir(): path
        +getExtension(): path
    }
    
    class LogFlags <<utility>> {
        +log_silent: bool
        +log_level: spdlog::level::level_enum
        +log_clear: bool
        +log_boring: bool
    }
}

/' ========== RELATIONSHIPS - TREE LAYOUT ========== '/

' Interface implementations (horizontal)
ILogger <|.. Logger
ILogger <|.. FakeLogger
IWebServer <|.. WebServer
IWebview <|.. Webview

' Inheritance
JSON <|-- Config

' App composition (tree from App)
App *-down- Config
App *-down- JSON
App *-down- IProcessManager
App *-down- IWebServer
App *-down- IWebview
App *-down- WindowFunctions
App *-down- PluginManager

' AppBuilder
AppBuilder .right.> App : builds
AppBuilder o-- Config
AppBuilder o-- JSON
AppBuilder o-- IProcessManager
AppBuilder o-- IWebServer
AppBuilder o-- IWebview
AppBuilder o-- WindowFunctions
AppBuilder o-- PluginManager

' WindowFunctions composition (tree from WindowFunctions)
WindowFunctions o-left- App : references
WindowFunctions *-down- "11" CallbackManager
WindowFunctions *-down- InOutManager

' PluginManager composition
PluginManager *-down- "*" Plugin : owns

' Args
Args *-down- CallbackManager

' Dependencies
App o-up- ILogger : uses
WebServer o-up- ILogger
WebServer o-right- App : references
Logger o-down- File
Logger *-down- LogFlags
WindowFunctions o-up- ILogger
JSON o-down- File
JSON o-up- ILogger
Config o-up- ILogger
Plugin o-up- ILogger
PluginManager o-up- ILogger

@enduml
