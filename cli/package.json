{
  "name": "renweb-cli",
  "version": "0.0.2",
  "description": "CLI tool for creating, building, running, and packaging RenWeb desktop applications.",
  "bin": {
    "rw": "index.js"
  },
  "files": [
    "index.js",
    "commands/",
    "project/"
  ],
  "keywords": [
    "renweb",
    "webview",
    "desktop",
    "cli",
    "scaffold"
  ],
  "author": "spur27",
  "license": "BSL-1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/spur27/RenWeb-Engine"
  },
  "homepage": "https://spur27.github.io/RenWeb-Engine/?page=cli",
  "engines": {
    "node": ">=16"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.0.0"
  },
  "scripts": {
    "start": "node index.js package -c --executable-only",
    "package": "node index.js package",
    "link": "npm link",
    "unlink": "npm unlink",
    "clean": "rm -rf release/",
    "docker:build": "docker build -t renweb-cli .",
    "docker:rebuild": "docker build --no-cache -t renweb-cli .",
    "docker:kill": "docker ps -q --filter ancestor=renweb-cli | xargs -r docker kill",
    "docker:clean": "docker rmi renweb-cli",
    "docker:shell": "docker run --rm -it -e IN_DOCKER=1 -v \"$(pwd):/work\" -w /work renweb-cli bash",
    "bootstrap": "npm install"
  }
}
